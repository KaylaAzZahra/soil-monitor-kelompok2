<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soil Monitoring Kel 2 | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { background-color: #0a192f; color: #64ffda; font-family: 'Rajdhani', sans-serif; }
        .card { background: rgba(17, 34, 64, 0.7); border: 1px solid #233554; }
        #history-table tr:first-child { color: #ffffff; background: rgba(100, 255, 218, 0.2); }
        .status-online { border-color: #22c55e; color: #22c55e; box-shadow: 0 0 15px rgba(34,197,94,0.3); }
        .status-offline { border-color: #ef4444; color: #ef4444; box-shadow: 0 0 15px rgba(239,68,68,0.3); }
    </style>
</head>
<body class="p-6 md:p-10">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-4xl font-bold tracking-tighter text-white">🌱 Soil Monitoring Kelompok 2</h1>
            <p class="text-base text-gray-400 uppercase tracking-[0.3em]">Soil Moisture Monitor</p>
        </div>
        <div id="connection-status" class="px-6 py-2 rounded-full border-2 font-bold uppercase transition-all duration-500 status-online">
            ● Terhubung
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="card p-6 rounded-2xl">
            <p class="text-sm uppercase text-gray-400 mb-2 tracking-widest font-semibold">Perangkat Aktif</p>
            <p id="mac-top" class="text-2xl font-bold text-white font-mono">--</p>
        </div>
        <div class="card p-6 rounded-2xl">
            <p class="text-sm uppercase text-gray-400 mb-2 tracking-widest font-semibold">Broker</p>
            <p class="text-2xl font-bold text-white">RabbitMQ</p>
        </div>
        <div class="card p-6 rounded-2xl">
            <p class="text-sm uppercase text-gray-400 mb-2 tracking-widest font-semibold">Last Update</p>
            <p id="time-top" class="text-2xl font-bold text-white">--</p>
        </div>
    </div>

    <div class="card rounded-2xl overflow-hidden shadow-2xl">
        <div class="p-5 bg-[#112240] border-b border-[#233554] flex justify-between items-center">
            <h3 class="text-lg font-bold uppercase tracking-widest text-white">Riwayat Pengukuran Terbaru</h3>
            <button onclick="clearHistory()" class="px-4 py-2 bg-red-500/10 border border-red-500/50 text-red-500 text-xs font-bold rounded-lg hover:bg-red-500 hover:text-white transition-all">
                HAPUS HISTORY
            </button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-sm uppercase text-gray-300 border-b border-[#233554] bg-[#0d1e36]">
                        <th class="p-5">Tanggal</th> 
                        <th class="p-5">Waktu</th>
                        <th class="p-5">MAC Address</th>
                        <th class="p-5 text-center">Nilai Sensor</th>
                        <th class="p-5">Status Tanah</th>
                    </tr>
                </thead>
                <tbody id="history-table" class="text-lg text-gray-200">
                    <tr><td colspan="5" class="p-10 text-center text-gray-500">Menunggu data sensor...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        let lastSeen = Date.now();
        const statusBadge = document.getElementById('connection-status');

        // Fungsi Cek Koneksi Alat (Timeout 6 detik)
        setInterval(() => {
            if (Date.now() - lastSeen > 6000) {
                statusBadge.innerText = "● Terputus";
                statusBadge.className = "px-6 py-2 rounded-full border-2 font-bold uppercase transition-all duration-500 status-offline";
            } else {
                statusBadge.innerText = "● Terhubung";
                statusBadge.className = "px-6 py-2 rounded-full border-2 font-bold uppercase transition-all duration-500 status-online";
            }
        }, 2000);

        async function clearHistory() {
            if(confirm("Hapus semua riwayat pengukuran?")) {
                await fetch('/clear-history');
                document.getElementById('history-table').innerHTML = "";
            }
        }

        const source = new EventSource('/stream');
        const tableBody = document.getElementById('history-table');

        source.onmessage = (event) => {
            const dataList = JSON.parse(event.data);
            
            if (dataList.length > 0) {
                lastSeen = Date.now(); // Update waktu terakhir data diterima
                document.getElementById('mac-top').innerText = dataList[0].mac || "--";
                document.getElementById('time-top').innerText = dataList[0].waktu || "--";

                let rows = "";
                dataList.forEach((item) => {
                    let statusClass = "text-green-400";
                    const statusText = item.status.toLowerCase();
                    if(statusText.includes('kering')) statusClass = "text-red-400";
                    else if(statusText.includes('lembab')) statusClass = "text-yellow-400";

                    rows += `
                        <tr class="border-b border-[#233554] hover:bg-[#1d2d47] transition-all">
                            <td class="p-5 text-gray-400 font-medium">${item.tanggal}</td>
                            <td class="p-5 font-mono text-base text-gray-400">${item.waktu}</td>
                            <td class="p-5 text-gray-200 font-medium">${item.mac}</td>
                            <td class="p-5 text-center font-bold text-2xl text-white">${Math.round(item.sensor)}</td>
                            <td class="p-5 uppercase font-bold ${statusClass} tracking-wider">${item.status}</td>
                        </tr>
                    `;
                });
                tableBody.innerHTML = rows;
            }
        };
    </script>
</body>
</html>